# =========================================================
#  RAG 后端配置 (.env)
#  复制本文件为 .env 并填入真实值
# =========================================================

# ---- 提供商选择 ----
# 可选: zhipu | openai_like | ollama
# 不同 provider 对应不同插件，安装了对应依赖才会出现在 /api/providers
LLM_PROVIDER=zhipu

# ---- 智谱 GLM (OpenAI 兼容协议) ----
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_API_KEY=your_zhipu_api_key_here
LLM_MODEL=glm-4
EMBEDDING_MODEL=embedding-3

# ---- 服务 ----
APP_HOST=127.0.0.1
APP_PORT=8000

# ---- 存储路径 ----
SQLITE_PATH=data/rag.db
UPLOAD_DIR=data/uploads

# ---- 上传限制 ----
MAX_FILE_SIZE_MB=20

# ---- 默认切分参数 ----
DEFAULT_CHUNK_SIZE=500
DEFAULT_CHUNK_OVERLAP=50

# ---- 检索 ----
DEFAULT_TOP_K=4

# ---- 认证 ----
# JWT 密钥：生产环境务必改为随机长字符串
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
# 首次启动时自动创建的初始管理员账号
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=admin123
